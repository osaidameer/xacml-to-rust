{%- if duration %}
use iso8601_duration::Duration as IsoDuration;
{%- endif %}
{%- if regex %}
use regex_automata::dfa::{Automaton, dense::DFA};
use regex_automata::Input;

fn eval_regex(regex_input: &str, regex_exp: &[u8]) -> bool {
    match DFA::from_bytes(regex_exp) {
        Ok((dfa, _)) => {
            let input = Input::new(regex_input);
            match dfa.try_search_fwd(&input) {
                Ok(result) => result.is_some(),
                Err(_) => false,
            }
        },
        Err(_) => false,
    }
}
{%- endif %}

{% for regex_claim in regex_claims %}
{{ regex_claim }}
{% endfor %}

#[derive(Debug, PartialEq)]
enum Result {
    Permit,
    Deny,
    NotApplicable,
}

{%- if time %}
fn parse_time(raw: &str) -> DateTime<FixedOffset> {
    let input = format!("1970-01-01T{}", raw);
    DateTime::parse_from_rfc3339(&input).unwrap()
}
{%- endif %}

{%- if duration %}
fn parse_duration(raw: &str) -> String {
    let is_negative = raw.starts_with('-');
    let trimmed = raw.trim_start_matches('-');

    let parsed = IsoDuration::parse(trimmed).unwrap().to_string();

    if is_negative {
        format!("-{}", parsed)
    } else {
        parsed
    }
}
{%- endif %}

{% for rule_fn in rule_functions %}
{{ rule_fn }}
{% endfor %}

{% for policy_fn in policy_functions %}
{{ policy_fn }}
{% endfor %}

{{ policyset_function }}

fn main() {
    let inp: Inputs = env::read();

    {% if policyset_function %}
    let decision = evaluate_policyset_{{ policyset_name }}(&inp);
    {% else %}
    let decision = match evaluate_policy_{{ policy_name }}(&inp) {
        Result::Permit => true,
        _ => false,
    };
    {% endif %}

    env::commit(&decision);
}
