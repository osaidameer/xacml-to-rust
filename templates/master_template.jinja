use policy_core::Inputs;
use regex::Regex;
use risc0_zkvm::guest::env;

#[derive(Debug)]
enum Result {
    Permit,
    Deny,
    NotApplicable,
}

{% for rule_fn in rule_functions %}
{{ rule_fn }}
{% endfor %}

{% for policy_fn in policy_functions %}
{{ policy_fn }}
{% endfor %}

{{ policyset_function }}

fn main() {
    let inp: Inputs = env::read();

    {% if policyset_function %}
    let decision = evaluate_policyset_{{ policyset_name }}(&inp);
    {% else %}
    let mut decision = false;
    let intermediate = evaluate_policy_{{ policy_name }}(&inp);
    if *intermediate == Result::Permit {
        decision = true;
    } else {
        decision = false;
    }
    {% endif %}

    env::commit(&decision);
}