<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<Policy xmlns="urn:oasis:names:tc:xacml:3.0:core:schema:wd-17"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        PolicyId="urn:oasis:names:tc:xacml:2.0:conformance-test:IIC057:policy"
        RuleCombiningAlgId="urn:oasis:names:tc:xacml:3.0:rule-combining-algorithm:deny-overrides"
        Version="1.0">

    <Description>
        Policy for Conformance Test IIC057 with JWT claim extraction.
    </Description>

    <Target>
      <AnyOf>
        <AllOf>
          <Match MatchId="urn:oasis:names:tc:xacml:1.0:function:string-greater-than-or-equal">
            <AttributeDesignator
              AttributeId="urn:custom:auth:jwt"
              Category="urn:oasis:names:tc:xacml:1.0:subject-category:access-subject"
              DataType="http://www.w3.org/2001/XMLSchema#string"
              MustBePresent="true"/>
              <AttributeValue DataType="http://www.w3.org/2001/XMLSchema#string"></AttributeValue>
          </Match>
        </AllOf>
      </AnyOf>
    </Target>

    <Rule Effect="Permit" RuleId="urn:oasis:names:tc:xacml:2.0:conformance-test:IIC057:rule">
        <Description>
            J K Hibbert and B O Simpson may perform any action on any resource.
            The subject_id claim is extracted from JWT.
        </Description>

        <Condition>

            <!-- Subject_id claim regex checks -->
            <Apply FunctionId="urn:oasis:names:tc:xacml:1.0:function:or">

                <!-- First pattern match -->
                <Apply FunctionId="urn:oasis:names:tc:xacml:1.0:function:string-regexp-match">
                    <AttributeValue DataType="http://www.w3.org/2001/XMLSchema#string">J.* K.* Hibbert</AttributeValue>
                    <Apply FunctionId="urn:oasis:names:tc:xacml:1.0:function:string-one-and-only">
                        <AttributeDesignator
                            AttributeId="subject_id"
                            Category="urn:oasis:names:tc:xacml:1.0:subject-category:access-subject"
                            DataType="http://www.w3.org/2001/XMLSchema#string"
                            MustBePresent="false"
                            FromJWT="true"/>
                    </Apply>
                </Apply>

                <!-- Second pattern match -->
                <Apply FunctionId="urn:oasis:names:tc:xacml:1.0:function:string-regexp-match">
                    <AttributeValue DataType="http://www.w3.org/2001/XMLSchema#string">B.* O.* Simpson</AttributeValue>
                    <Apply FunctionId="urn:oasis:names:tc:xacml:1.0:function:string-one-and-only">
                        <AttributeDesignator
                            AttributeId="subject_id"
                            Category="urn:oasis:names:tc:xacml:1.0:subject-category:access-subject"
                            DataType="http://www.w3.org/2001/XMLSchema#string"
                            MustBePresent="false"
                            FromJWT="true"/>
                    </Apply>
                </Apply>

            </Apply>

        </Condition>

    </Rule>
</Policy>
